@using eAgenda.WebApp.Modulos.ModuloCategoria.Apresentacao


@model CadastrarCategoriaViewModel

@{
    ViewBag.Titulo = "Cadastrar Categoria";
}

<div class="content-panel p-4">
    <h2 class="h4 mb-1">Nova Categoria</h2>
    <p class="text-secondary mb-4">
        Informe os dados da categoria para realizar o cadastro.
    </p>
    <form asp-action="Cadastrar" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Titulo" class="form-label">Título da categoria</label>
            <input asp-for="Titulo" class="form-control" placeholder="Ex: Trabalho, Estudos, Pessoal..." />
            <span asp-validation-for="Titulo" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
            <a asp-action="Listar" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>