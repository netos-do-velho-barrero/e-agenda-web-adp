@using eAgenda.WebApp.Modulos.ModuloCategoria.Apresentacao


@model EditarCategoriaViewModel

@{
    ViewBag.Titulo = "Editar Categoria";
}

<div class="content-panel p-4">

    <h2 class="h4 mb-1">Editar Categoria</h2>

    <p class="text-secondary mb-4">
        Atualize os dados da categoria.
    </p>

    <form asp-action="Editar" method="post">

        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="Titulo" class="form-label">Título da categoria</label>
            <input asp-for="Titulo" class="form-control" />
            <span asp-validation-for="Titulo" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
            <a class="btn btn-outline-secondary" asp-action="Listar">Voltar</a>
        </div>

    </form>

</div>