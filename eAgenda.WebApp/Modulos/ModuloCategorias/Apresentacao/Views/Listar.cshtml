@model List<eAgenda.WebApp.Modulos.ModuloCategoria.Apresentacao.ListarCategoriaViewModel>

@{
    ViewBag.Titulo = "Categorias";
}

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-primary" asp-controller="Categoria" asp-action="Cadastrar">Cadastrar Categoria</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhuma categoria cadastrada.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Titulo</th>
                <th class="text-end">Acoes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var categoria in Model)
            {
                <tr>
                    <td>@categoria.Titulo</td>
                    <td class="text-end">
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Categoria" asp-action="Despesas"
                           asp-route-id="@categoria.Id">
                            Despesas
                        </a>

                        <a class="btn btn-outline-primary btn-sm" asp-controller="Categoria" asp-action="Editar"
                           asp-route-id="@categoria.Id">
                            Editar
                        </a>

                        <a class="btn btn-outline-danger btn-sm" asp-controller="Categoria" asp-action="Excluir"
                           asp-route-id="@categoria.Id">
                            Excluir
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}