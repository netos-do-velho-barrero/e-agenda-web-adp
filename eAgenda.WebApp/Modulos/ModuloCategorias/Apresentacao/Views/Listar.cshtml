@model List<eAgenda.WebApp.Modulos.ModuloCategoria.Apresentacao.ListarCategoriaViewModel>

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Categorias";
}

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-controller="Categoria" asp-action="Cadastrar">
    Cadastrar Categoria
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma categoria cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="card-title mb-0">@c.Titulo</h5>
                            <span class="badge text-bg-primary rounded-pill">#@c.Id</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">
                                Título
                            </dt>

                            <dd class="col-7 mb-0 text-break">
                                @c.Titulo
                            </dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 justify-content-end mt-auto">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-controller="Categoria"
                               asp-action="Despesas" asp-route-id="@c.Id">
                                Despesas
                            </a>

                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-controller="Categoria"
                               asp-action="Editar" asp-route-id="@c.Id">
                                Editar
                            </a>

                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-controller="Categoria"
                               asp-action="Excluir" asp-route-id="@c.Id">
                                Excluir
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}
