@using eAgenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@model CadastrarDespesaViewModel

@{
    ViewBag.Titulo = "Cadastrar Despesa";
}

<div class="content-panel p-4">
    <h2 class="h4 mb-1">Nova Despesa</h2>
    <p class="text-secondary mb-4">
        Informe os dados da despesa para realizar o cadastro.
    </p>
    
    <form asp-action="Cadastrar" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Descricao" class="form-label">Descrição</label>
            <input asp-for="Descricao" class="form-control" placeholder="Ex: Gasolina, Almoço, Software..." />
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="DataOcorrencia" class="form-label">Data da Ocorrência</label>
                <input asp-for="DataOcorrencia" type="date" class="form-control" />
                <span asp-validation-for="DataOcorrencia" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Valor" class="form-label">Valor (R$)</label>
                <input asp-for="Valor" type="number" step="0.01" class="form-control" placeholder="0,00" />
                <span asp-validation-for="Valor" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="FormaPagamento" class="form-label">Forma de Pagamento</label>
            <select asp-for="FormaPagamento" asp-items="ViewBag.FormasPagamento" class="form-select">
                <option value="">Selecione a forma de pagamento...</option>
            </select>
            <span asp-validation-for="FormaPagamento" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="CategoriaIds" class="form-label">Categorias Relacionadas</label>
            <select asp-for="CategoriaIds" asp-items="ViewBag.Categorias" class="form-select" multiple>
            </select>
            <span asp-validation-for="CategoriaIds" class="text-danger small"></span>
            <div class="form-text text-muted">Mantenha o botão Ctrl (ou Cmd) pressionado para selecionar mais de uma.</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Cadastrar</button>
            <a asp-action="Listar" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>