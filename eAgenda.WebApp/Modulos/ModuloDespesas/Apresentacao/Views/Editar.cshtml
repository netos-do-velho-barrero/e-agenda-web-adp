@using eAgenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@model EditarDespesaViewModel

@{
    ViewBag.Titulo = "Editar Despesa";
}

<div class="content-panel p-4">
    <h2 class="h4 mb-1">Editar Despesa</h2>
    <p class="text-secondary mb-4">
        Atualize os dados da despesa.
    </p>

    <form asp-action="Editar" method="post">
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Descricao" class="form-label">Descrição</label>
            <input asp-for="Descricao" class="form-control" />
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="DataOcorrencia" class="form-label">Data da Ocorrência</label>
                <input asp-for="DataOcorrencia" type="date" class="form-control" />
                <span asp-validation-for="DataOcorrencia" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Valor" class="form-label">Valor (R$)</label>
                <input asp-for="Valor" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Valor" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="FormaPagamento" class="form-label">Forma de Pagamento</label>
            <select asp-for="FormaPagamento" asp-items="ViewBag.FormasPagamento" class="form-select"></select>
            <span asp-validation-for="FormaPagamento" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="CategoriaIds" class="form-label">Categorias Relacionadas</label>
            <select asp-for="CategoriaIds" asp-items="ViewBag.Categorias" class="form-select" multiple></select>
            <span asp-validation-for="CategoriaIds" class="text-danger small"></span>
            <div class="form-text text-muted">Mantenha Ctrl pressionado para selecionar múltiplas opções.</div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
            <a class="btn btn-outline-secondary" asp-action="Listar">Voltar</a>
        </div>
    </form>
</div>