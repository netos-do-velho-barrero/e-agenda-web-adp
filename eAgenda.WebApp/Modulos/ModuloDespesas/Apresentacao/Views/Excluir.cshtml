@using eAgenda.WebApp.Modulos.ModuloDespesas.Apresentacao
@model ExcluirDespesaViewModel

@{
    ViewBag.Titulo = "Excluir Despesa";
}

<div class="content-panel p-4">
    <div class="alert alert-warning">
        Tem certeza que deseja excluir esta despesa?
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="border rounded p-3">
                <span class="text-secondary small">Descrição da Despesa</span>
                <div class="fw-semibold">@Model.Descricao</div>
            </div>
        </div>
    </div>

    <form asp-action="Excluir" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
                Confirmar exclusão
            </button>
            <a class="btn btn-outline-secondary" asp-action="Listar">
                Cancelar
            </a>
        </div>
    </form>
</div>