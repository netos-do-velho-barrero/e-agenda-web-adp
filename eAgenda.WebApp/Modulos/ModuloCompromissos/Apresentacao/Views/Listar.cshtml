
@model List<eAgenda.WebApp.Modulos.ModuloCompromissos.Apresentacao.ListarCompromissosViewModel>

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Compromissos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fs-3 text-primary fw-semibold">@ViewBag.Titulo</h1>

  
    <a class="btn btn-primary rounded-pill px-4" asp-controller="Compromisso" asp-action="Cadastrar">
        Cadastrar
    </a>
</div>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger">@mensagemErro</div>
}

<div class="card border-primary-subtle shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Assunto</th>
                    <th>Data</th>
                    <th>Inicio</th>
                    <th>Termino</th>
                    <th>Tipo</th>
                    <th class="text-end">Acoes</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var compromisso in Model)
                {
                    <tr>
                        <td>@compromisso.Assunto</td>
                        <td>@compromisso.DataOcorrencia.ToString("dd/MM/yyyy")</td>
                        <td>@compromisso.HoraInicio.ToString("HH\\:mm")</td>
                        <td>@compromisso.HoraTermino.ToString("HH\\:mm")</td>
                        <td>@compromisso.Tipo</td>
                        <td class="text-end">
                           
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" 
                               asp-controller="Compromisso" 
                               asp-action="Editar"
                               asp-route-id="@compromisso.Id">
                                Editar
                            </a>

                            
                            <a class="btn btn-outline-danger btn-sm rounded-pill px-3" 
                               asp-controller="Compromisso" 
                               asp-action="Excluir"
                               asp-route-id="@compromisso.Id">
                                Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>