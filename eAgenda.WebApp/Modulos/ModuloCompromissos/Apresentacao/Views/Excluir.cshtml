@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusao de Compromisso";
}

@model ExcluirCompromissoViewModel

<form class="card border-danger-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Excluir"
      method="post">
    <input asp-for="Id" type="hidden">

    <p class="fs-5 mb-4">
        Deseja realmente excluir o compromisso <strong>@Model.Assunto</strong>?
    </p>

    <dl class="row mb-4">
        <dt class="col-sm-3 text-primary">Data</dt>
        <dd class="col-sm-9">@Model.DataOcorrencia.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3 text-primary">Horario</dt>
        <dd class="col-sm-9">@Model.HoraInicio.ToString("HH\\:mm") - @Model.HoraTermino.ToString("HH\\:mm")</dd>

        <dt class="col-sm-3 text-primary">Tipo</dt>
        <dd class="col-sm-9">@Model.Tipo</dd>

        <dt class="col-sm-3 text-primary">Local</dt>
        <dd class="col-sm-9">@(Model.Local ?? "-")</dd>

        <dt class="col-sm-3 text-primary">Link</dt>
        <dd class="col-sm-9">@(Model.Link ?? "-")</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Cancelar</a>
        <button class="btn btn-danger rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>