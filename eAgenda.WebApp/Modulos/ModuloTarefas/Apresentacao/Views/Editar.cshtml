@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edicao de Tarefa";
}

@model EditarTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Editar"
      asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Titulo</label>
        <input asp-for="Titulo" type="text" class="form-control">
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small">Prioridade</label>
        <select asp-for="Prioridade" class="form-select"
                asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()"></select>
        <span asp-validation-for="Prioridade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Itens</label>

        @for (int i = 0; i < Model.Itens.Count; i++)
        {
            <div class="border rounded p-3 mb-2">
                <input name="Itens[@i].Id" type="hidden" value="@Model.Itens[i].Id">

                <div class="mb-2">
                    <label class="form-label small fw-semibold">Titulo</label>
                    <input name="Itens[@i].Titulo" value="@Model.Itens[i].Titulo" type="text" class="form-control">
                </div>

                <div class="form-check">
                    <input name="Itens[@i].Concluido" value="true" type="checkbox" class="form-check-input"
                           checked="@Model.Itens[i].Concluido">
                    <input name="Itens[@i].Concluido" value="false" type="hidden">
                    <label class="form-check-label">Concluido</label>
                </div>
            </div>
        }

        @{
            int inicioNovosItens = Model.Itens.Count;
        }

        @for (int i = 0; i < 3; i++)
        {
            int indice = inicioNovosItens + i;

            <div class="border rounded p-3 mb-2">
                <input name="Itens[@indice].Id" type="hidden" value="@Guid.Empty">

                <div class="mb-2">
                    <label class="form-label small fw-semibold">Novo item</label>
                    <input name="Itens[@indice].Titulo" type="text" class="form-control" placeholder="Novo item @(i + 1)">
                </div>

                <input name="Itens[@indice].Concluido" value="false" type="hidden">
            </div>
        }
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>