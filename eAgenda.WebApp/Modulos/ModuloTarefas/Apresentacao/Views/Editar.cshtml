@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edicao de Tarefa";
}

@model EditarTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Editar"
      method="post">

    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <select asp-for="Prioridade" class="form-select" asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()">
        </select>
        <span asp-validation-for="Prioridade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">
            Itens
        </label>

        @for (int i = 0; i < Model.Itens.Count; i++)
        {
            <div class="border rounded p-3 mb-2">

                <input asp-for="Itens[i].Id" type="hidden" />

                <div class="mb-2">
                    <label asp-for="Itens[i].Titulo" class="form-label small fw-semibold"></label>
                    <input asp-for="Itens[i].Titulo" class="form-control" />
                    <span asp-validation-for="Itens[i].Titulo" class="text-danger"></span>
                </div>

                <div class="form-check">
                    <input asp-for="Itens[i].Concluido" class="form-check-input" />
                    <label asp-for="Itens[i].Concluido" class="form-check-label">
                        Concluído
                    </label>
                </div>

            </div>
        }
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Listar" class="btn btn-outline-primary rounded-pill px-4">
            Voltar
        </a>

        <button type="submit" class="btn btn-primary rounded-pill px-4">
            Confirmar
        </button>
    </div>
</form>