@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Tarefa";
}

@model CadastrarTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Cadastrar"
      method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Titulo</label>
        <input asp-for="Titulo" type="text" class="form-control">
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small">Prioridade</label>
        <select asp-for="Prioridade" class="form-select"
                asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()"></select>
        <span asp-validation-for="Prioridade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">Itens</label>

        @for (int i = 0; i < 5; i++)
        {
            <input name="Itens[@i]" type="text" class="form-control mb-2" placeholder="Item @(i + 1)">
        }
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>