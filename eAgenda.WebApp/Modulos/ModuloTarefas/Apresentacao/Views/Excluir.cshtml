@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusao de Tarefa";
}

@model ExcluirTarefaViewModel

<form class="card border-danger-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Excluir" method="post">
    <input asp-for="Id" type="hidden">

    <p class="fs-5 mb-4">
        Deseja realmente excluir a tarefa <strong>@Model.Titulo</strong>?
    </p>

    <dl class="row mb-4">
        <dt class="col-sm-3 text-primary">Prioridade</dt>
        <dd class="col-sm-9">@Model.Prioridade</dd>

        <dt class="col-sm-3 text-primary">Status</dt>
        <dd class="col-sm-9">@(Model.Concluida ? "Concluida" : "Pendente")</dd>

        <dt class="col-sm-3 text-primary">Percentual</dt>
        <dd class="col-sm-9">@Model.PercentualConcluido.ToString("0")%</dd>
    </dl>

    @if (Model.Itens.Count > 0)
    {
        <div class="mb-4">
            <h2 class="fs-6 text-primary text-uppercase fw-semibold">Itens</h2>

            <ul class="list-group">
                @foreach (var item in Model.Itens)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @item.Titulo

                        <span class="badge rounded-pill @(item.Concluido ? "text-bg-success" : "text-bg-secondary")">
                            @(item.Concluido ? "Concluido" : "Pendente")
                        </span>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Cancelar</a>
        <button class="btn btn-danger rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>