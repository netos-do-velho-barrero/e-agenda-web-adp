@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Tarefas";
}

@model List<ListarTarefasViewModel>

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    Cadastrar
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar">
        Todas
    </a>

    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar" asp-route-filtro="pendentes">
        Pendentes
    </a>

    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar" asp-route-filtro="concluidas">
        Concluídas
    </a>

    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar" asp-route-filtro="prioridade"
       asp-route-prioridade="Alta">
        Alta
    </a>

    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar" asp-route-filtro="prioridade"
       asp-route-prioridade="Normal">
        Normal
    </a>

    <a class="btn btn-outline-primary rounded-pill px-3" asp-action="Listar" asp-route-filtro="prioridade"
       asp-route-prioridade="Baixa">
        Baixa
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma tarefa cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var t in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">@t.Titulo</h5>

                            <span class="badge text-bg-primary rounded-pill flex-shrink-0" title="@t.Id">
                                #@t.Id.ToString()[..8]
                            </span>
                        </div>

                        <dl class="row g-2 mb-4">

                            <dt class="col-5 text-secondary fw-semibold">
                                Prioridade
                            </dt>
                            <dd class="col-7 mb-0">
                                @t.Prioridade
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold">
                                Status
                            </dt>
                            <dd class="col-7 mb-0">
                                @(t.Concluida ? "Concluída" : "Pendente")
                            </dd>

                            <dt class="col-12 text-secondary fw-semibold">
                                Progresso
                            </dt>

                            <dd class="col-12 mb-0">
                                <div class="progress" style="height:22px;">
                                    <div class="progress-bar" style="width:@t.PercentualConcluido%">
                                        @t.PercentualConcluido.ToString("0")%
                                    </div>
                                </div>
                            </dd>

                        </dl>

                        <div class="d-flex flex-wrap gap-2 justify-content-end mt-auto">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                               asp-route-id="@t.Id">
                                Editar
                            </a>

                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                               asp-route-id="@t.Id">
                                Excluir
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}