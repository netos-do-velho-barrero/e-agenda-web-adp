@using eAgenda.WebApp.Modulos.ModuloContatos.Apresentacao

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Contatos";
}

@model List<ListarContatosViewModel>

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    Cadastrar
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhum contato cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (var c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">@c.Nome</h5>

                            <span class="badge text-bg-primary rounded-pill flex-shrink-0" title="@c.Id">
                                #@c.Id.ToString()[..8]
                            </span>
                        </div>

                        <dl class="row g-2 mb-4">

                            <dt class="col-5 text-secondary fw-semibold">
                                Email
                            </dt>
                            <dd class="col-7 mb-0 text-break">
                                @c.Email
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold">
                                Telefone
                            </dt>
                            <dd class="col-7 mb-0">
                                @c.Telefone
                            </dd>

                        </dl>

                        <div class="d-flex flex-wrap gap-2 justify-content-end mt-auto">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                               asp-route-id="@c.Id">
                                Editar
                            </a>

                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                               asp-route-id="@c.Id">
                                Excluir
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}