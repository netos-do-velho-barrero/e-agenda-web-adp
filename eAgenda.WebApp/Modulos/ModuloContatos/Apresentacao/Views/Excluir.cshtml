@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusao de Contato";
}

@model ExcluirContatoViewModel

<form class="card border-danger-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir"
      method="post">
    <input asp-for="Id" type="hidden">

    <p class="fs-5 mb-4">
        Deseja realmente excluir o contato <strong>@Model.Nome</strong>?
    </p>

    <dl class="row mb-4">
        <dt class="col-sm-3 text-primary">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3 text-primary">Telefone</dt>
        <dd class="col-sm-9">@Model.Telefone</dd>

        <dt class="col-sm-3 text-primary">Cargo</dt>
        <dd class="col-sm-9">@Model.Cargo</dd>

        <dt class="col-sm-3 text-primary">Empresa</dt>
        <dd class="col-sm-9">@Model.Empresa</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Cancelar</a>
        <button class="btn btn-danger rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>