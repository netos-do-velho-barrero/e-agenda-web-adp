@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row g-3">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">e-Agenda</h1>

        <p class="lead text-secondary mb-4">
            Organize Contatos, Compromissos, Categorias, Despesas e Tarefas de forma simples.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Contato" asp-action="Listar">
                Contatos
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Compromisso" asp-action="Listar">
                Compromissos
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Categoria" asp-action="Listar">
                Categorias
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Despesa" asp-action="Listar">
                Despesas
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Tarefa" asp-action="Listar">
                Tarefas
            </a>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
                <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Contato" asp-action="Listar">
                        Controle de Contatos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Compromisso" asp-action="Listar">
                        Controle de Compromissos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Categoria" asp-action="Listar">
                        Controle de Categorias
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Despesa" asp-action="Listar">
                        Controle de Despesas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Tarefa" asp-action="Listar">
                        Controle de Tarefas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>