@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="p-4 p-lg-5 mb-4 rounded-4 text-white" style="background: linear-gradient(120deg, #085247, #0d8a77);">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <span class="badge rounded-pill bg-white text-success mb-3 py-2 px-3">
                <i class="bi bi-lightning-fill me-1"></i> Produtividade Diária
            </span>

            <h2 class="display-6 fw-bold">Organize sua rotina com total simplicidade.</h2>

            <p class="lead mb-4 opacity-75">
                Gerencie seus compromissos, tarefas, contatos e finanças pessoais de forma integrada em uma interface elegante.
            </p>

            <a class="btn btn-light text-success fw-semibold px-4 py-2 me-sm-2" asp-controller="Compromisso" asp-action="Listar">
                <i class="bi bi-calendar-event me-2"></i>Ver compromissos
            </a>

            <a class="btn btn-outline-light fw-semibold px-4 py-2 mt-2 mt-sm-0" asp-controller="Tarefa" asp-action="Listar">
                <i class="bi bi-plus-circle me-2"></i>Acessar tarefas
            </a>
        </div>

        <div class="col-lg-4 text-center d-none d-lg-block">
            <i class="bi bi-calendar-check style" style="font-size: 9rem; opacity: .20;"></i>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h3 class="h5 fw-bold mb-1">Módulos de Organização</h3>
        <p class="text-secondary mb-0">Acesse e gerencie suas informações rapidamente.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <a class="card h-100 border-0 bg-primary-subtle text-decoration-none shadow-sm" asp-controller="Contato" asp-action="Listar">
            <div class="card-body p-4">
                <i class="bi bi-person-lines-fill fs-2 text-primary"></i>
                <h4 class="h6 fw-bold text-dark mt-3">Contatos</h4>
                <p class="small text-secondary mb-0">Cadastro completo, telefones e e-mails importantes.</p>
            </div>
        </a>
    </div>

    <div class="col-xl-4 col-md-6">
        <a class="card h-100 border-0 bg-success-subtle text-decoration-none shadow-sm" asp-controller="Compromisso" asp-action="Listar">
            <div class="card-body p-4">
                <i class="bi bi-calendar-event fs-2 text-success"></i>
                <h4 class="h6 fw-bold text-dark mt-3">Compromissos</h4>
                <p class="small text-secondary mb-0">Agendamentos diários, locais e horários de reuniões.</p>
            </div>
        </a>
    </div>

    <div class="col-xl-4 col-md-6">
        <a class="card h-100 border-0 bg-info-subtle text-decoration-none shadow-sm" asp-controller="Categoria" asp-action="Listar">
            <div class="card-body p-4">
                <i class="bi bi-tags fs-2 text-info"></i>
                <h4 class="h6 fw-bold text-dark mt-3">Categorias</h4>
                <p class="small text-secondary mb-0">Agrupamentos para classificar despesas e tarefas.</p>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a class="card h-100 border-danger-subtle text-decoration-none shadow-sm" asp-controller="Despesa" asp-action="Listar">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <i class="bi bi-cash-coin fs-1 text-danger"></i>
                <div>
                    <h4 class="h6 fw-bold text-dark mb-1">Controle Financeiro</h4>
                    <p class="small text-secondary mb-0">Registre pagamentos, custos e controle despesas diárias.</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6">
        <a class="card h-100 border-warning-subtle text-decoration-none shadow-sm" asp-controller="Tarefa" asp-action="Listar">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <i class="bi bi-check2-square fs-1 text-warning"></i>
                <div>
                    <h4 class="h6 fw-bold text-dark mb-1">Listagem de Tarefas</h4>
                    <p class="small text-secondary mb-0">Crie listas de afazeres com prioridades e prazos.</p>
                </div>
            </div>
        </a>
    </div>
</div>