@{
    string controllerAtual = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Titulo - e-Agenda</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        :root {
            --agenda-principal: #0b6e5f;
            --agenda-escuro: #085247;
            --agenda-claro: #e6f4f2;
            --agenda-texto: #1c3531;
        }

        body {
            min-height: 100vh;
            background: #f4f9f8;
            color: var(--agenda-texto);
        }

        .navbar {
            background: linear-gradient(110deg, var(--agenda-escuro), var(--agenda-principal)) !important;
        }

        .navbar-brand {
            color: white !important;
        }

        .navbar-brand i {
            background: rgba(255, 255, 255, .15);
            padding: .55rem;
            border-radius: .75rem;
        }

        .navbar .nav-link {
            color: rgba(255, 255, 255, .8) !important;
            border-radius: .6rem;
            padding: .5rem .75rem !important;
        }

        .navbar .nav-link:hover,
        .navbar .nav-link.active {
            color: white !important;
            background: rgba(255, 255, 255, .14);
        }

        .page-header {
            background: white;
            border-bottom: 1px solid #ddebe8;
        }

        .page-header small {
            color: var(--agenda-principal);
            font-weight: 700;
            letter-spacing: .08em;
        }

        .content-shell {
            background: white;
            border: 1px solid #e2f0ed;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 .35rem 1.5rem rgba(11, 110, 95, .05);
        }

        .btn-primary {
            --bs-btn-bg: var(--agenda-principal);
            --bs-btn-border-color: var(--agenda-principal);
            --bs-btn-hover-bg: var(--agenda-escuro);
            --bs-btn-hover-border-color: var(--agenda-escuro);
        }

        footer {
            color: #728a85;
        }
    </style>
</head>

<body class="d-flex flex-column">
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container py-2">
            <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-calendar-check"></i>
                <span>e-Agenda</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav ms-auto gap-lg-1 mt-3 mt-lg-0">
                    <a class="nav-link @(controllerAtual == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-grid me-1"></i> Início</a>
                    <a class="nav-link @(controllerAtual == "Contato" ? "active" : "")" asp-controller="Contato" asp-action="Listar"><i class="bi bi-person-lines-fill me-1"></i> Contatos</a>
                    <a class="nav-link @(controllerAtual == "Compromisso" ? "active" : "")" asp-controller="Compromisso" asp-action="Listar"><i class="bi bi-calendar-event me-1"></i> Compromissos</a>
                    <a class="nav-link @(controllerAtual == "Categoria" ? "active" : "")" asp-controller="Categoria" asp-action="Listar"><i class="bi bi-tags me-1"></i> Categorias</a>
                    <a class="nav-link @(controllerAtual == "Despesa" ? "active" : "")" asp-controller="Despesa" asp-action="Listar"><i class="bi bi-cash-coin me-1"></i> Despesas</a>
                    <a class="nav-link @(controllerAtual == "Tarefa" ? "active" : "")" asp-controller="Tarefa" asp-action="Listar"><i class="bi bi-check2-square me-1"></i> Tarefas</a>
                </div>
            </div>
        </div>
    </nav>

    <header class="page-header">
        <div class="container py-4">
            <small>ORGANIZAÇÃO E PRODUTIVIDADE</small>
            <h1 class="h3 fw-bold mb-0 mt-1">@ViewBag.Titulo</h1>
        </div>
    </header>

    <main class="container flex-grow-1 py-4">
        @if (TempData["MensagemErro"] is string mensagemErro)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 border-start border-danger border-4">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@mensagemErro
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["MensagemSucesso"] is string mensagemSucesso)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-start border-success border-4">
                <i class="bi bi-check-circle-fill me-2"></i>@mensagemSucesso
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <section class="content-shell">
            @RenderBody()
        </section>
    </main>

    <footer class="container py-4 text-center small mt-auto">
        <i class="bi bi-shield-check me-1"></i>
        e-Agenda &copy; @DateTime.Now.Year — Gestão simplificada da sua rotina
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>