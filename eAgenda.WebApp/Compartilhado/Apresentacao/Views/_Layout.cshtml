<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Titulo - e-Agenda</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                e-Agenda
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav ms-auto">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                    <a class="nav-link" asp-controller="Contato" asp-action="Listar">Contatos</a>
                    <a class="nav-link" asp-controller="Compromisso" asp-action="Listar">Compromissos</a>
                    <a class="nav-link" asp-controller="Categoria" asp-action="Listar">Categorias</a>
                    <a class="nav-link" asp-controller="Despesa" asp-action="Listar">Despesas</a>
                    <a class="nav-link" asp-controller="Tarefa" asp-action="Listar">Tarefas</a>
                </div>
            </div>
        </div>
    </nav>

    <header class="container py-4">
        <h2>@ViewBag.Titulo</h2>
    </header>

    <main class="container pb-5">
        @if (TempData["MensagemErro"] is string mensagemErro)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @mensagemErro
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["MensagemSucesso"] is string mensagemSucesso)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @mensagemSucesso
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>